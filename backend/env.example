# Copy this file to .env and fill in your values

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-jwt-secret

# SMTP (optional — for email receipts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=you@gmail.com
SMTP_FROM_NAME=DineFlow Billing

# Telegram Bot (optional — for Telegram bill notifications)
# Create a bot via @BotFather on Telegram, copy the token here
TELEGRAM_BOT_TOKEN=123456789:ABCDefgh-your-bot-token

# AI Campaign Message Generation (optional — use one of these)
# Gemini (free tier): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
# OpenAI (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
